# ─────────────────────────────────────────────────────────────────────────────
#  .env.staging
#
#  Переменные для docker-compose.staging.yml (top-level).
#  Не путать с Backend/.env и Baza/.env — это разные файлы.
#
#  При первом деплое:
#    cp .env.staging.example .env.staging
#    # отредактировать пароли
#
#  Файл .env.staging НЕ коммитится в git (см. .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# === MySQL ===================================================================
MYSQL_DATABASE=systo
MYSQL_USER=systo
MYSQL_PASSWORD=staging_secret_CHANGE_ME
MYSQL_ROOT_PASSWORD=staging_root_secret_CHANGE_ME

# === Baza (на тот же MySQL, но другая БД) ===================================
# Базу создаст migration / seeder, главное чтобы пользователь имел право CREATE
BAZA_DB_DATABASE=baza

# === RabbitMQ (брокер для будущей интеграции qr→org) ========================
# Management UI наружу через host-nginx (rabbit.staging.spaceofjoy.ru) + basic-auth.
# AMQP (5672) — только внутри docker-сети staging, host не пробрасываем.
# Пароль на первом деплое заменяется на openssl rand (см. deploy-staging.yml).
RABBITMQ_DEFAULT_USER=systo
RABBITMQ_DEFAULT_PASS=staging_rabbit_secret_CHANGE_ME
RABBITMQ_DEFAULT_VHOST=systo
