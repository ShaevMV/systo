APP_FRONT_URL=https://org.solarsysto.ru
APP_BAZA_URL=http://baza.spaceofjoy.ru

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


DB_CONNECTION=mysql
DB_HOST=mysql
