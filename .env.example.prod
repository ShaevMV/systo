# ==================== PROD Environment ====================

# Nginx configuration
NGINX_PORT=80

# Frontend API URL (update to your production domain)
VUE_APP_API_URL=https://your-domain.com/

# Frontend WebSocket port (должен совпадать с NGINX_PORT)
VUE_APP_WS_PORT=80

# Backend hosts
ENV_ORG_BACKEND_HOST=php.org
ENV_ORG_FRONTEND_HOST=node.org
ENV_VHOD_BACKEND_HOST=php.vhod
ENV_DRUG_BACKEND_HOST=php.drug
ENV_SPISOK_BACKEND_HOST=php.spisok

# Backend paths
ENV_ORG_BACKEND_PATCH=/var/www/org
ENV_ORG_FRONT_PATCH=/var/www/app
ENV_VHOD_PATCH=/var/www/vhod
ENV_DRUG_PATCH=/var/www/drug
ENV_SPISOK_PATCH=/var/www/spisok
ENV_SHARED_PATCH=/var/www/Shared

# MySQL credentials (PROD - USE STRONG PASSWORDS!)
MYSQL_ROOT_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
MYSQL_USER=default
MYSQL_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
MYSQL_DATABASE=systo

# MySQL Friendly (database) credentials (PROD - USE STRONG PASSWORDS!)
MYSQL_FRIENDLY_ROOT_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
